// RECD Project & Service Tracker - data model
//
// Design rule (see project memory): anything that might grow a new value
// later - stages, statuses, roles, permissions, photo checkpoints, structure
// types - is a row in a lookup table, never a hardcoded Prisma enum. Prisma
// `enum` is used only for genuinely fixed, structural categories that are
// not expected to grow (e.g. pending-action owner type, complaint severity).
// Well-known lookup-table `key` values that application code branches on
// live in packages/shared/src/constants.ts and must match the seed data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Transaction-mode pooler (IPv4, pgbouncer) - what the running app uses for queries.
  url       = env("DATABASE_URL")
  // Session-mode pooler - what `prisma migrate` uses; transaction-mode pgbouncer doesn't
  // reliably support the advisory locks and DDL migrations need.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Auth, roles, permissions
// ---------------------------------------------------------------------------

model Role {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String?  @unique
  phone               String?  @unique
  passwordHash        String?
  isActive            Boolean  @default(true)
  mustChangePassword  Boolean  @default(true)
  /// Informal job title shown in the UI only (e.g. "Proprietor", "CTO", "Fitter", "Welder") -
  /// does not affect permissions, which come entirely from `role`.
  title               String?
  roleId              String
  role                Role     @relation(fields: [roleId], references: [id])
  customerId          String?
  customer            Customer? @relation("CustomerContacts", fields: [customerId], references: [id])
  /// Erection engineers belong to an external Vendor company (work is subcontracted). Null = internal staff.
  vendorId            String?
  vendor              Vendor?   @relation("VendorMembers", fields: [vendorId], references: [id])
  notificationChannels Json?   // array of NotificationChannel keys the user has opted into
  createdAt           DateTime @default(now())

  salesOrders          Order[]            @relation("SalesEngineer")
  customersOwned       Customer[]         @relation("CustomerSalesOwner")
  assignedSites        Site[]             @relation("AssignedEngineer")
  stageEventsCreated   SiteStageEvent[]
  photosUploaded       SitePhoto[]
  complaintsAssigned   Complaint[]        @relation("AssignedTo")
  pendingActionsOwned  PendingAction[]    @relation("InternalOwner")
  usersCreated         User[]             @relation("CreatedBy")
  createdById          String?
  createdBy            User?              @relation("CreatedBy", fields: [createdById], references: [id])
  otpCodes             OtpCode[]
  vendorsApproved      Vendor[]           @relation("VendorApprover")
  quotationsCreated    Quotation[]        @relation("QuotationCreator")
  invoicesCreated      Invoice[]          @relation("InvoiceCreator")
  paymentsReceived     PaymentReceived[]  @relation("PaymentReceivedRecorder")
  purchaseOrdersCreated PurchaseOrder[]  @relation("PurchaseOrderCreator")
  billsRecorded        Bill[]             @relation("BillRecorder")
  paymentsMade         PaymentMade[]      @relation("PaymentMadeRecorder")
  expensesRecorded     Expense[]          @relation("ExpenseRecorder")
  workOrdersAssigned   WorkOrder[]        @relation("WorkOrderAssignee")
  workOrdersCreated    WorkOrder[]        @relation("WorkOrderCreator")
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Customers & products
// ---------------------------------------------------------------------------

model Customer {
  id            String   @id @default(cuid())
  name          String
  address       String?
  /// GST identification number (printed on documents; drives IGST vs CGST/SGST).
  gstin         String?
  /// Billing state - the customer's state for place-of-supply / interstate checks.
  state         String?
  billingAddress String?
  salesOwnerId  String?
  salesOwner    User?    @relation("CustomerSalesOwner", fields: [salesOwnerId], references: [id])
  createdAt     DateTime @default(now())

  contacts  User[]   @relation("CustomerContacts")
  orders    Order[]
  complaints Complaint[]
  quotations Quotation[]
  invoices   Invoice[]
}

/// External erection subcontractor. Not part of Platino. Self-registers, is approved by
/// management after due diligence, then its erection engineers are added as vendor-scoped users.
model Vendor {
  id           String    @id @default(cuid())
  name         String
  /// "pending" | "approved" | "rejected" - see VENDOR_STATUS in packages/shared.
  status       String    @default("pending")
  contactName  String
  contactEmail String    @unique
  contactPhone String?
  address      String?
  approvedById String?
  approvedBy   User?     @relation("VendorApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())

  members User[] @relation("VendorMembers")
  sites   Site[] @relation("VendorSites")
  suppliers Supplier[]
}

model Product {
  id             String   @id @default(cuid())
  name           String
  model          String   @unique
  ratingSpec     String?
  /// Drives structure/scaffold sizing later - RECD weight scales proportionately with this.
  capacityKva    Decimal? @db.Decimal(10, 2)
  warrantyMonths Int?
  createdAt      DateTime @default(now())

  orders Order[]
  quotationLineItems QuotationLineItem[]
  invoiceLineItems   InvoiceLineItem[]
}

// ---------------------------------------------------------------------------
// Orders & sites
// ---------------------------------------------------------------------------

model Order {
  id                       String    @id @default(cuid())
  orderNumber              String    @unique
  customerId               String
  customer                 Customer  @relation(fields: [customerId], references: [id])
  productId                String
  product                  Product   @relation(fields: [productId], references: [id])
  quantity                 Int
  value                    Decimal   @db.Decimal(12, 2)
  orderDate                DateTime
  promisedDeliveryDate     DateTime?
  actualDispatchDate       DateTime?
  /// Set by the sales engineer at order time - "replace_existing_silencer" | "add_after_existing_exhaust"
  plannedExhaustHookupType String?
  salesEngineerId          String?
  salesEngineer            User?     @relation("SalesEngineer", fields: [salesEngineerId], references: [id])
  /// Customer-issued PO to us (they order via their own PO number).
  customerPoNumber        String?
  customerPoDate          DateTime?
  createdAt                DateTime  @default(now())

  site Site?
  invoices Invoice[]
  purchaseOrders PurchaseOrder[]
  quotations Quotation[]
}

model Site {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  address           String?
  gpsLat            Decimal? @db.Decimal(9, 6)
  gpsLng            Decimal? @db.Decimal(9, 6)
  assignedEngineerId String?
  assignedEngineer   User?   @relation("AssignedEngineer", fields: [assignedEngineerId], references: [id])

  /// The external vendor company responsible for erecting this site (null = handled internally).
  vendorId String?
  vendor   Vendor? @relation("VendorSites", fields: [vendorId], references: [id])

  currentStageId String
  currentStage   StageDefinition @relation(fields: [currentStageId], references: [id])

  /// Set by the erection engineer on-site once they've seen the generator. If it differs
  /// from order.plannedExhaustHookupType, see the PendingAction created for customer approval.
  confirmedExhaustHookupType String?

  // Structure / scaffold module - schema ready now, no UI behind it until Phase 2.
  dgCapacityKva        Decimal?  @db.Decimal(10, 2)
  dgModel              String?
  structureTypeId      String?
  structureType        StructureType? @relation(fields: [structureTypeId], references: [id])
  structureDimensions  Json?
  structureDiagramUrl  String?
  structureDiagramStatus String? // null | "pending" | "ready" - stays "pending" until Phase 2 engine exists

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stageEvents     SiteStageEvent[]
  photos          SitePhoto[]
  pendingActions  PendingAction[]
  complaints      Complaint[]
  purchaseOrders  PurchaseOrder[]
  expenses        Expense[]
  workOrders      WorkOrder[]
}

// ---------------------------------------------------------------------------
// SITC stages & field status updates - lookup tables, not enums
// ---------------------------------------------------------------------------

enum SitcPhase {
  SUPPLY
  INSTALLATION
  TESTING
  COMMISSIONING
}

model StageDefinition {
  id            String    @id @default(cuid())
  key           String    @unique
  label         String
  phase         SitcPhase
  sequenceOrder Int
  createdAt     DateTime  @default(now())

  sites       Site[]
  stageEvents SiteStageEvent[]
}

/// Domain distinguishes which workflow a status option belongs to, so one table
/// can serve site-stage updates now and other workflows later without new tables.
model StatusOption {
  id              String   @id @default(cuid())
  domain          String   @default("site_stage")
  key             String
  label           String
  requiresComment Boolean  @default(true)
  sequenceOrder   Int
  createdAt       DateTime @default(now())

  stageEvents SiteStageEvent[]

  @@unique([domain, key])
}

model SiteStageEvent {
  id                String          @id @default(cuid())
  siteId            String
  site              Site            @relation(fields: [siteId], references: [id])
  stageDefinitionId String
  stageDefinition   StageDefinition @relation(fields: [stageDefinitionId], references: [id])
  statusOptionId    String
  statusOption      StatusOption    @relation(fields: [statusOptionId], references: [id])
  comment           String
  photoUrl          String?
  createdById       String
  createdBy         User            @relation(fields: [createdById], references: [id])
  createdAt         DateTime        @default(now())
}

// ---------------------------------------------------------------------------
// Photo checkpoints
// ---------------------------------------------------------------------------

model PhotoCheckpoint {
  id            String   @id @default(cuid())
  key           String   @unique
  label         String
  sequenceOrder Int
  createdAt     DateTime @default(now())

  photos SitePhoto[]
}

model SitePhoto {
  id           String          @id @default(cuid())
  siteId       String
  site         Site            @relation(fields: [siteId], references: [id])
  checkpointId String
  checkpoint   PhotoCheckpoint @relation(fields: [checkpointId], references: [id])
  photoUrl     String
  caption      String?
  uploadedById String
  uploadedBy   User            @relation(fields: [uploadedById], references: [id])
  uploadedAt   DateTime        @default(now())
}

// ---------------------------------------------------------------------------
// Structure diagram module - Phase 2, schema ready now
// ---------------------------------------------------------------------------

model StructureType {
  id              String   @id @default(cuid())
  key             String   @unique
  name            String
  /// JSON schema describing the parameters this structure type takes
  /// (e.g. dgCapacityKva, footprintLength, footprintWidth, platformHeight,
  /// legCount, bracingPattern, material, recdMountHeight).
  parameterSchema Json
  createdAt       DateTime @default(now())

  sites    Site[]
  examples StructureTemplateExample[]
}

model StructureTemplateExample {
  id              String        @id @default(cuid())
  structureTypeId String
  structureType   StructureType @relation(fields: [structureTypeId], references: [id])
  imageUrl        String
  parameters      Json
  notes           String?
  uploadedById    String
  uploadedAt      DateTime      @default(now())
}

// ---------------------------------------------------------------------------
// Pending actions (customer/internal/vendor approvals and blockers)
// ---------------------------------------------------------------------------

enum PendingActionOwnerType {
  INTERNAL
  CUSTOMER
  VENDOR
}

model PendingAction {
  id              String                 @id @default(cuid())
  siteId          String
  site            Site                   @relation(fields: [siteId], references: [id])
  /// e.g. "customer_approval", "material_shortage", "customer_signoff_pending" - see
  /// PENDING_ACTION_CATEGORY in packages/shared. Free-form on purpose; not a lookup
  /// table since these are created by code paths, not picked from a UI dropdown.
  category        String
  description     String
  ownerType       PendingActionOwnerType
  ownerUserId     String?
  ownerUser       User?                  @relation("InternalOwner", fields: [ownerUserId], references: [id])
  dueDate         DateTime?
  priority        String                 @default("medium") // low | medium | high | critical
  status          String                 @default("open")   // open | resolved
  escalationLevel Int                    @default(0)
  resolution      String?
  createdAt       DateTime               @default(now())
  resolvedAt      DateTime?
}

// ---------------------------------------------------------------------------
// Complaints
// ---------------------------------------------------------------------------

model Complaint {
  id             String    @id @default(cuid())
  ticketNumber   String    @unique
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  siteId         String?
  site           Site?     @relation(fields: [siteId], references: [id])
  category       String    // erection_commissioning | delivery_delay | non_performance
  description    String
  severity       String    // low | medium | high | critical
  status         String    @default("open") // see COMPLAINT_STATUS in packages/shared
  assignedToId   String?
  assignedTo     User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  rootCause      String?
  resolutionNotes String?
  createdAt      DateTime  @default(now())
  closedAt       DateTime?
}

// ---------------------------------------------------------------------------
// Work orders (internal task dispatch to field crews)
// ---------------------------------------------------------------------------

/// Internal document that instructs an erection/commissioning/service engineer to do
/// specific work at a site - distinct from Site.currentStage (the site's overall SITC
/// progress) and from PurchaseOrder (procurement from external suppliers). Not a money
/// document; no GST/sequential numbering requirement, so ticketNumber-style random ids
/// are fine (see Complaint.ticketNumber).
model WorkOrder {
  id              String    @id @default(cuid())
  workOrderNumber String    @unique // WO-2026-00001
  siteId          String
  site            Site      @relation(fields: [siteId], references: [id])
  /// installation | repair | amc_service | inspection | other (WORK_ORDER_TASK_TYPE in shared)
  taskType        String
  title           String
  instructions    String?
  /// draft | assigned | in_progress | completed | cancelled (WORK_ORDER_STATUS in shared)
  status          String    @default("draft")
  assignedToId    String?
  assignedTo      User?     @relation("WorkOrderAssignee", fields: [assignedToId], references: [id])
  scheduledDate   DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  completionNotes String?
  completionPhotoUrl String?
  createdById     String
  createdBy       User      @relation("WorkOrderCreator", fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

model NotificationLog {
  id            String   @id @default(cuid())
  recipientId   String
  channel       String   // in_app | email | sms | whatsapp | telegram
  templateKey   String
  payload       Json
  /// "sent" for live channels, "pending_provider_setup" for stubbed channels (sms/whatsapp/telegram)
  status        String
  sentAt        DateTime?
  createdAt     DateTime @default(now())
}

model CompanySettings {
  id            String   @id @default("singleton")
  logoDataUrl   String?
  themeKey      String   @default("emerald")
  customColors  Json?

  /// Legal entity details printed on finance documents.
  legalName            String?
  address              String?
  state                String?
  gstin                String?
  pan                  String?
  bankName             String?
  bankAccountNumber    String?
  bankIfsc             String?
  bankBranch           String?
  invoiceTerms         String?
  quotationTerms      String?
  purchaseOrderTerms   String?
  defaultTaxRatePct    Decimal? @db.Decimal(5, 2)

  /// Authorised signatory printed on quotations, invoices and purchase orders.
  signatoryName        String?
  signatoryDataUrl     String?
}

// ---------------------------------------------------------------------------
// Finance module (see docs/FINANCE_MODULE_PLAN.md)
// ---------------------------------------------------------------------------

/// Atomic per-fiscal-year number sequences for finance documents.
/// docType: "quotation" | "proforma" | "tax_invoice" | "purchase_order"
/// fiscalYear: "2026-27" (Indian FY, April-March)
model DocumentSequence {
  id         String @id @default(cuid())
  docType    String
  fiscalYear String
  lastNumber Int    @default(0)

  @@unique([docType, fiscalYear])
}

/// Material/service supplier (steel, piping, transport, subcontract labour).
/// Distinct from Vendor (erection subcontractors with an approval workflow);
/// vendorId optionally links a supplier record to an approved Vendor so POs
/// can be raised for subcontracted erection work.
model Supplier {
  id           String   @id @default(cuid())
  name         String
  gstin        String?
  state        String?
  address      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  vendorId     String?  @unique
  vendor       Vendor?  @relation(fields: [vendorId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  purchaseOrders PurchaseOrder[]
  bills          Bill[]
  paymentsMade   PaymentMade[]
}

model Quotation {
  id             String    @id @default(cuid())
  quoteNumber    String    @unique          // QTN/2026-27/0001
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  /// draft | sent | accepted | rejected | expired | converted  (QUOTATION_STATUS in shared)
  status         String    @default("draft")
  issueDate      DateTime
  validUntil     DateTime?
  placeOfSupply  String?                    // customer state; drives CGST/SGST vs IGST
  subtotal       Decimal   @db.Decimal(12, 2)
  discountAmount Decimal   @db.Decimal(12, 2) @default(0)
  cgstAmount     Decimal   @db.Decimal(12, 2) @default(0)
  sgstAmount     Decimal   @db.Decimal(12, 2) @default(0)
  igstAmount     Decimal   @db.Decimal(12, 2) @default(0)
  total          Decimal   @db.Decimal(12, 2)
  notes          String?
  terms          String?
  createdById    String
  createdBy      User      @relation("QuotationCreator", fields: [createdById], references: [id])
  /// Set when "Convert to order" is used; links the resulting Order.
  convertedOrderId String? @unique
  convertedOrder   Order?  @relation(fields: [convertedOrderId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lineItems QuotationLineItem[]
  invoices  Invoice[]
}

model QuotationLineItem {
  id           String    @id @default(cuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?  @relation(fields: [productId], references: [id])
  description  String
  hsnCode      String?
  quantity     Decimal   @db.Decimal(10, 2)
  unitPrice    Decimal   @db.Decimal(12, 2)
  discountPct  Decimal   @db.Decimal(5, 2)  @default(0)
  taxRatePct   Decimal   @db.Decimal(5, 2)  @default(18)
  lineTotal    Decimal   @db.Decimal(12, 2) // qty * unitPrice * (1-disc%) - pre-tax
  sortOrder    Int       @default(0)
}

model Invoice {
  id             String    @id @default(cuid())
  invoiceNumber  String    @unique          // PI/2026-27/0001 or INV/2026-27/0001
  /// "proforma" | "tax_invoice"  (INVOICE_DOC_TYPE in shared)
  docType        String
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  orderId        String?
  order          Order?    @relation(fields: [orderId], references: [id])
  quotationId    String?
  quotation      Quotation? @relation(fields: [quotationId], references: [id])
  /// draft | issued | partially_paid | paid | cancelled  (INVOICE_STATUS in shared;
  /// "overdue" is computed at read time from dueDate + status, never stored)
  status         String    @default("draft")
  issueDate      DateTime
  dueDate        DateTime?
  placeOfSupply  String?
  subtotal       Decimal   @db.Decimal(12, 2)
  discountAmount Decimal   @db.Decimal(12, 2) @default(0)
  cgstAmount     Decimal   @db.Decimal(12, 2) @default(0)
  sgstAmount     Decimal   @db.Decimal(12, 2) @default(0)
  igstAmount     Decimal   @db.Decimal(12, 2) @default(0)
  total          Decimal   @db.Decimal(12, 2)
  notes          String?
  terms          String?
  createdById    String
  createdBy      User      @relation("InvoiceCreator", fields: [createdById], references: [id])
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lineItems InvoiceLineItem[]
  payments  PaymentReceived[]
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  hsnCode     String?
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  discountPct Decimal @db.Decimal(5, 2)  @default(0)
  taxRatePct  Decimal @db.Decimal(5, 2)  @default(18)
  lineTotal   Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)
}

model PaymentReceived {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id])
  amount       Decimal  @db.Decimal(12, 2)
  /// bank_transfer | upi | cheque | cash | other  (PAYMENT_METHOD in shared)
  method       String
  reference    String?  // UTR / cheque no / UPI ref
  receivedDate DateTime
  notes        String?
  recordedById String
  recordedBy   User     @relation("PaymentReceivedRecorder", fields: [recordedById], references: [id])
  createdAt    DateTime @default(now())
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  poNumber     String   @unique             // PO/2026-27/0001
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  /// draft | issued | partially_received | received | cancelled | closed  (PO_STATUS in shared)
  status       String   @default("draft")
  orderDate    DateTime
  expectedDate DateTime?
  /// Optional job-costing links: which customer order / site this spend is for.
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id])
  siteId       String?
  site         Site?    @relation(fields: [siteId], references: [id])
  subtotal     Decimal  @db.Decimal(12, 2)
  cgstAmount   Decimal  @db.Decimal(12, 2) @default(0)
  sgstAmount   Decimal  @db.Decimal(12, 2) @default(0)
  igstAmount   Decimal  @db.Decimal(12, 2) @default(0)
  total        Decimal  @db.Decimal(12, 2)
  notes        String?
  terms        String?
  createdById  String
  createdBy    User     @relation("PurchaseOrderCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lineItems PurchaseOrderLineItem[]
  bills     Bill[]
}

model PurchaseOrderLineItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  description     String
  hsnCode         String?
  quantity        Decimal       @db.Decimal(10, 2)
  unitPrice       Decimal       @db.Decimal(12, 2)
  taxRatePct      Decimal       @db.Decimal(5, 2)  @default(18)
  lineTotal       Decimal       @db.Decimal(12, 2)
  sortOrder       Int           @default(0)
}

/// A bill received FROM a supplier (their invoice to us). billNumber is the
/// supplier's own number - unique per supplier, not globally.
model Bill {
  id              String         @id @default(cuid())
  billNumber      String
  supplierId      String
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  /// unpaid | partially_paid | paid | cancelled  (BILL_STATUS in shared)
  status          String         @default("unpaid")
  billDate        DateTime
  dueDate         DateTime?
  subtotal        Decimal        @db.Decimal(12, 2)
  taxAmount       Decimal        @db.Decimal(12, 2) @default(0)
  total           Decimal        @db.Decimal(12, 2)
  notes           String?
  recordedById    String
  recordedBy      User           @relation("BillRecorder", fields: [recordedById], references: [id])
  createdAt       DateTime       @default(now())

  payments PaymentMade[]

  @@unique([supplierId, billNumber])
}

model PaymentMade {
  id           String    @id @default(cuid())
  billId       String?
  bill         Bill?     @relation(fields: [billId], references: [id])
  supplierId   String
  supplier     Supplier  @relation(fields: [supplierId], references: [id])
  amount       Decimal   @db.Decimal(12, 2)
  method       String
  reference    String?
  paidDate     DateTime
  notes        String?
  recordedById String
  recordedBy   User      @relation("PaymentMadeRecorder", fields: [recordedById], references: [id])
  createdAt    DateTime  @default(now())
}

/// Lookup table (data-not-code): expense categories are seeded rows so new
/// categories are a DB insert, not a code change.
model ExpenseCategory {
  id            String   @id @default(cuid())
  key           String   @unique
  label         String
  sequenceOrder Int
  createdAt     DateTime @default(now())

  expenses Expense[]
}

/// Simple expense book for non-PO spend (fuel, travel, site consumables, misc).
model Expense {
  id           String          @id @default(cuid())
  categoryId   String
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  description  String
  amount       Decimal         @db.Decimal(12, 2)
  expenseDate  DateTime
  method       String          // PAYMENT_METHOD keys
  siteId       String?
  site         Site?           @relation(fields: [siteId], references: [id])
  receiptUrl   String?         // base64 data-URL, same convention as SitePhoto
  recordedById String
  recordedBy   User            @relation("ExpenseRecorder", fields: [recordedById], references: [id])
  createdAt    DateTime        @default(now())
}
